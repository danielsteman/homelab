# Harbor reads settings from `harbor.yml` (not from a .env file).
#
# Before first start:
#   1. Edit harbor.yml: hostname, harbor_admin_password, database.password
#   2. For GitOps secrets, encrypt a copy with SOPS (see repo secrets/README.md)
#
# Optional: pin installer image (defaults match harbor.yml _version)
# HARBOR_VERSION=v2.15.0
